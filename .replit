modules = ["ruby-3.2", "nodejs-20", "python-3.11"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node dev-proxy.js & (cd worker && node_modules/.bin/wrangler dev --port 8787 2>&1 &) ; cd site && bundle exec jekyll serve --host 127.0.0.1 --port 8080 --livereload --livereload-port 35729"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "static"
build = ["bash", "-c", "cd site && bundle install && bundle exec jekyll build"]
publicDir = "site/_site"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000
