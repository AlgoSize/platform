# Algosize — environment variable reference.
# Worker secrets are NOT loaded from this file in production. Use:
#   cd worker && wrangler secret put <NAME>
# This file just documents what each secret is for so a new operator
# knows what to provision.

# --- Stripe ---
# Test keys for local dev, live keys for production. Never commit real values.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
# Price ID for the monthly subscription plan.
STRIPE_PRICE_ID=price_replace_me

# --- Auth ---
# 32+ random bytes, hex or base64. Used to sign session JWTs.
JWT_SECRET=replace_with_long_random_string

# --- Cloudflare KV namespace IDs ---
# Created with `wrangler kv:namespace create SESSIONS` and `... USERS`,
# then pasted into worker/wrangler.toml. Listed here only for the operator.
KV_SESSIONS_ID=
KV_USERS_ID=

# --- Site ---
# Origin the Worker should allow via CORS.
SITE_ORIGIN=http://localhost:5000

# Cookie name used for the session JWT (set by the Stripe webhook in Task #4,
# read by requireAuth on every protected route).
COOKIE_NAME=algosize_session
